# Optional: move the local SQLite auth DB outside the project root.
# On Railway, attach a Volume to the service. The app automatically uses
# RAILWAY_VOLUME_MOUNT_PATH for the SQLite DB directory when it is available.
# PIGMA_DATA_DIR=C:\pigma-data
# PIGMA_AUTH_DB=C:\pigma-data\pigma.sqlite

# Public app URL used for billing redirects and Google OAuth callbacks.
# Local: http://localhost:3000
# Production: https://oy-tools-production.up.railway.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable Google login/signup.
# Create an OAuth client and set the redirect URIs to:
# http://localhost:3000/auth/google/callback
# https://oy-tools-production.up.railway.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin emails that can open /admin and manually set a user's plan.
# The owner email ohgun5020@gmail.com is always included.
PIGMA_ADMIN_EMAILS=ohgun5020@gmail.com

# Free users receive temporary Basic access for this many days after signup.
PIGMA_BASIC_TRIAL_DAYS=7

# Paddle subscription billing.
# Client-side token is created in Paddle > Developer tools > Authentication.
# API key must be server-side only. Give it customer_portal_session.write
# so logged-in customers can open authenticated billing management links.
# Use "sandbox" only with sandbox prices and a sandbox client-side token.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
PADDLE_ENVIRONMENT=production
PADDLE_WEBHOOK_SECRET=
PADDLE_BASIC_PRICE_ID=pri_01ksktfy8dsq6zjj4nq29hwz2x
PADDLE_PRO_PRICE_ID=pri_01ksktgy40nsef59aed9s4g24p
# Optional: Paddle customer portal URL from Business account > Customer portal.
PADDLE_CUSTOMER_PORTAL_URL=

# Optional: server-side AI proxy for Pro users.
# Keep OPENAI_API_KEY server-side only. The plugin should call /api/plugin/ai
# with its plugin token instead of reading this key directly.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PIGMA_AI_MAX_OUTPUT_TOKENS=1200
# Set to true only if clients may choose the model while using the server key.
PIGMA_AI_ALLOW_CLIENT_MODEL=false

# Optional: Magnific image proxy for the Figma plugin.
# If MAGNIFIC_API_KEY is empty, users can enter a Magnific key in the plugin settings.
MAGNIFIC_API_KEY=
# Used to show remaining monthly credits in the plugin UI.
MAGNIFIC_MONTHLY_CREDIT_LIMIT=
# Magnific does not expose a universal preflight cost endpoint in the docs.
# Tune this estimate to match your actual Analytics usage.
MAGNIFIC_PRECISION_V2_CREDITS_PER_MEGAPIXEL=1
# Optional: set these to true only if Magnific routes should require a PIGMA plugin token / Pro plan.
MAGNIFIC_PLUGIN_REQUIRE_TOKEN=false
MAGNIFIC_PLUGIN_REQUIRE_PRO=false

# Optional: public notice JSON for plugin release notes.
# Keep R2 access keys server-side only. The Figma plugin calls /api/admin/notices
# with an admin plugin token; it never receives these secrets.
PIGMA_NOTICE_PUBLIC_URL=https://pub-8e2f2ec9d22c4c97b52fe244b86bc4cf.r2.dev/notices/pigma-notices.json
PIGMA_NOTICE_OBJECT_KEY=notices/pigma-notices.json
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=pigma-assets
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
