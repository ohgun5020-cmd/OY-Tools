# Optional: move the local SQLite auth DB outside the project root.
# On Railway, attach a Volume to the service. The app automatically uses
# RAILWAY_VOLUME_MOUNT_PATH for the SQLite DB directory when it is available.
# PIGMA_DATA_DIR=C:\pigma-data
# PIGMA_AUTH_DB=C:\pigma-data\pigma.sqlite

# Public app URL used for billing redirects and Google OAuth callbacks.
# Local: http://localhost:3000
# Production: https://oy-tools-production.up.railway.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable Google login/signup.
# Create an OAuth client and set the redirect URIs to:
# http://localhost:3000/auth/google/callback
# https://oy-tools-production.up.railway.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Paddle subscription billing.
# Client-side token is created in Paddle > Developer tools > Authentication.
# Use "sandbox" only with sandbox prices and a sandbox client-side token.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_ENVIRONMENT=production
PADDLE_WEBHOOK_SECRET=
PADDLE_BASIC_PRICE_ID=pri_01ksktfy8dsq6zjj4nq29hwz2x
PADDLE_PRO_PRICE_ID=pri_01ksktgy40nsef59aed9s4g24p
# Optional: Paddle customer portal URL from Business account > Customer portal.
PADDLE_CUSTOMER_PORTAL_URL=
