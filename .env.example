# Optional: move the local SQLite auth DB outside the project root.
# On Railway, attach a Volume to the service. The app automatically uses
# RAILWAY_VOLUME_MOUNT_PATH for the SQLite DB directory when it is available.
# PIGMA_DATA_DIR=C:\pigma-data
# PIGMA_AUTH_DB=C:\pigma-data\pigma.sqlite

# Optional: enable Google login/signup.
# Create an OAuth client and set the redirect URI to:
# http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
